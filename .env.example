# Get your free Groq API key at https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Get your free YouTube Data API v3 key at https://console.cloud.google.com
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# For YouTube playlist creation (OAuth - optional)
# Create OAuth 2.0 Client ID at https://console.cloud.google.com
# Set Authorized JavaScript origins to http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
